{
  "name": "agentforge",
  "version": "1.0.0",
  "description": "AgentForge — AI desktop powered by Claude Code",
  "main": "main.js",
  "scripts": {
    "start":    "electron .",
    "dev":      "NODE_ENV=development electron .",
    "build":    "electron-builder --mac --win --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "electron-log": "^5.2.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.claudelocal.app",
    "productName": "AgentForge",
    "icon": "assets/icon",
    "files": ["main.js", "preload.js", "assets/**"],
    "extraResources": [{ "from": "../backend", "to": "backend" }],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "your-github-username",
      "repo": "agentforge"
    }
  }
}
