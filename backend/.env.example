# AgentForge Backend — environment config
# Copy to .env and fill in your values

# ── Enterprise Security (REQUIRED) ────────────────────────────────
# Generate a strong secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret_before_deploying
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ── CORS — comma-separated list of allowed frontend origins ───────
# Default allows local dev. Add your production URL in prod.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Claude / AI Authentication (ONE of the following) ─────────────
#
# Option 1: Anthropic API key (recommended for production)
#   Get one at: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option 2: Bearer token / LLM gateway proxy
# ANTHROPIC_AUTH_TOKEN=your-bearer-token
#
# Option 3: Long-lived OAuth token (for CI without browser)
#   Generate with: claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token
#
# Option 4: Already authenticated via `claude /login`
#   Credentials are stored in your keychain / ~/.claude/.credentials.json
#   and will be used automatically — no env var needed.
#
# Option 5: AWS Bedrock
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
#
# Option 6: Google Vertex AI
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=your-project
# CLOUD_ML_REGION=us-central1

# ── Server ports ───────────────────────────────────────────────────
BACKEND_PORT=9000
FRONTEND_PORT=5173

# ── Optional Claude Code overrides ───────────────────────────────
# CLAUDE_WORKING_DIR=~/projects
# CLAUDE_MODEL=claude-opus-4-5
# CLAUDE_SYSTEM_PROMPT=You are a helpful senior engineer.
