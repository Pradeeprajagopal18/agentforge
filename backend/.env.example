# AgentForge Backend — environment config
# Copy to .env and fill in your values

# ── Authentication (ONE of the following — in priority order) ──────
#
# Option 1: Anthropic API key (recommended for AgentForge / production)
#   Get one at: https://console.anthropic.com
#   Billed per token. Works everywhere including headless/server mode.
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option 2: Bearer token / LLM gateway proxy
# ANTHROPIC_AUTH_TOKEN=your-bearer-token
#
# Option 3: Long-lived OAuth token (for CI without browser)
#   Generate with: claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token
#
# Option 4: Already authenticated via `claude /login`
#   If you ran `claude /login` on this machine, credentials are stored
#   in your keychain / ~/.claude/.credentials.json and will be used
#   automatically — no env var needed here.
#
# Option 5: AWS Bedrock
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
# (+ standard AWS credential chain: env vars, ~/.aws/credentials, IAM role)
#
# Option 6: Google Vertex AI
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=your-project
# CLOUD_ML_REGION=us-central1

# ── Server ports ───────────────────────────────────────────────────
BACKEND_PORT=9000
FRONTEND_PORT=5173

# ── Optional Claude Code overrides ───────────────────────────────
# CLAUDE_WORKING_DIR=~/projects
# CLAUDE_MODEL=claude-opus-4-5
# CLAUDE_SYSTEM_PROMPT=You are a helpful senior engineer.
